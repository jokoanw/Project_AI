import google.generativeai as genai

# Ini API Key kamu yang tadi
genai.configure(api_key="AIzaSyDqAxi0m6xbiYL1D2ELaTDvrxcaSZtjJrA")

model = genai.GenerativeModel('gemini-1.5-flash')

